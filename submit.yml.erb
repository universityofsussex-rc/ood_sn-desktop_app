---
batch_connect:
  template: vnc
script:
  copy_environment: true    
  native:
    - "--mem-per-cpu"
    - "<%= num_RAM.blank? ? 4 : num_RAM.to_i %>G"
    - "--cpus-per-task"
    - "<%= num_cores.blank? ? 1 : num_cores.to_i %>"
    - "--ntasks-per-node"
    - "<%= num_tasks.blank? ? 1 : num_tasks.to_i %>"
    - "--nodes"
    - "<%= num_nodes.blank? ? 1 : num_nodes.to_i %>"
    <%- if gpus_per_node.include?("0") -%>
    - "--gres"
    - "gpu:A40:<%= gpus_per_node.to_i %>"
    <%- end -%>