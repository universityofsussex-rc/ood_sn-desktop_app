#!/usr/bin/env bash

# Change working directory to user's home directory
cd "${HOME}"

# Reset module environment (may require login shell for some HPC clusters)
module purge

#Setup Custom XDG Directories
export XDG_CONFIG_HOME="${HOME}/.sn_desktop_config"
export XDG_DATA_HOME="${HOME}/.sn_desktop_data"
export XDG_DESKTOP_DIR="${HOME}/SN_Desktop"

# Ensure that the user's configured login shell is used
export SHELL="$(getent passwd $USER | cut -d: -f7)"

# Force module path
export MODULEPATH=/mnt/shared/easybuild/modules/all:/mnt/shared/modulefiles:/etc/scl/modulefiles:/opt/ohpc/pub/modulefiles

# Double check display settings
echo "DISPLAY:"
echo $DISPLAY


# Load custom env file
<%- if context.custom_env -%>
echo "Running Custom User Env Script"
echo <%= context.custom_env -%>
source <%= context.custom_env -%>
<%- end -%>

# Default allow for outbound traffic via squid
module load proxy

# SN Environment - TODO SPYDER
module load FSL/6.0.7-foss-2021a
module load ConnectomeWorkbench/2.1.0-GCCcore-10.3.0
module load FreeSurfer/6.0.0-foss-2021a-centos6_x86_64
module load MATLAB/R2022b-GCCcore-10.3.0
module load ImageMagick/7.0.11-14-GCCcore-10.3.0


# Start up desktop
echo "Launching desktop '<%= context.desktop %>'..."
source "<%= session.staged_root.join("desktops", "#{context.desktop}.sh") %>"
echo "Desktop '<%= context.desktop %>' ended with $? status..."
