#!/usr/bin/env bash
# Load Lmod so "module" works
if [ -f /etc/profile.d/lmod.sh ]; then
    source /etc/profile.d/lmod.sh
elif [ -f /usr/share/lmod/lmod/init/profile ]; then
    source /usr/share/lmod/lmod/init/profile
fi
# Change working directory to user's home directory
cd "${HOME}"

# Reset module environment (may require login shell for some HPC clusters)
module purge

#Setup Custom XDG Directories
export XDG_CONFIG_HOME="${HOME}/.sn_desktop_config"
export XDG_DATA_HOME="${HOME}/.sn_desktop_data"
export XDG_DESKTOP_DIR="${HOME}/SN_Desktop"

# Ensure that the user's configured login shell is used
export SHELL="$(getent passwd $USER | cut -d: -f7)"

# Force module path
export MODULEPATH=/mnt/shared/easybuild/modules/all:/mnt/shared/modulefiles:/etc/scl/modulefiles:/opt/ohpc/pub/modulefiles

# Double check display settings
echo "DISPLAY:"
echo $DISPLAY


# Load custom env file
<%- if context.custom_env -%>
echo "Running Custom User Env Script"
echo <%= context.custom_env -%>
source <%= context.custom_env -%>
<%- end -%>

# Default allow for outbound traffic via squid
module load proxy

# SN Environment - TODO SPYDER
module load FSL/6.0.7-foss-2021a
module load ConnectomeWorkbench/2.1.0-GCCcore-10.3.0
module load FreeSurfer/6.0.0-foss-2021a-centos6_x86_64
module load MATLAB/R2022b-GCCcore-10.3.0
module load ImageMagick/7.0.11-14-GCCcore-10.3.0

# Chris R bashrc
alias ll='ls -l'
alias la='ls -A'
alias l='ls -CF'

alias rm='rm -i'
alias mv='mv -i'
alias cp='cp -i'

alias rsvl='squeue -p visionlab -o "%.18i %.9P %.8j %.8u %.2t %.6C %.10m %.6D %R"'
alias rscs='squeue -p cisc -o "%.18i %.9P %.8j %.8u %.2t %.6C %.10m %.6D %R"'
alias rssn='squeue -p sussexneuro -o "%.18i %.9P %.8j %.8u %.2t %.6C %.10m %.6D %R"'
alias rsgn='squeue -p general -o "%.18i %.9P %.8j %.8u %.2t %.6C %.10m %.6D %R"'
alias rsvlng='squeue -p verylong -o "%.18i %.9P %.8j %.8u %.2t %.6C %.10m %.6D %R"'
alias rslng='squeue -p long -o "%.18i %.9P %.8j %.8u %.2t %.6C %.10m %.6D %R"'
alias rsst='squeue -p short -o "%.18i %.9P %.8j %.8u %.2t %.6C %.10m %.6D %R"'

export MLM_LICENSE_FILE=/mnt/shared/easybuild/software/MATLAB/license
export MATLABPATH=$MATLABPATH:~/SN_Documents/MATLAB
export PYTHONPATH=/research/cisc2/shared/heudiconv:$
export HCPPIPEDIR=/research/cisc2/shared/HCPpipelines-5.0.0
export QUNEX=/mnt/lustre/scratch/psych/cr291/QuNex_HCP_experiments
export PATH=${QUNEX}:/its/home/cr291/.local/bin:/research/cisc2/shared/heudiconv/bin:$HCPPIPEDIR/FreeSurfer/custom:$PATH



# Start up desktop
echo "Launching desktop '<%= context.desktop %>'..."
source "<%= session.staged_root.join("desktops", "#{context.desktop}.sh") %>"
echo "Desktop '<%= context.desktop %>' ended with $? status..."
